{
  "cron": [
    {
      "command": "python -u cli.py load --env demo &> /var/log/dokku/apps/dashboard-backend/load-demo.log",
      "schedule": "2 6 * * *"
    },
    {
      "command": "python -u cli.py load --env prod &> /var/log/dokku/apps/dashboard-backend/load-prod.log",
      "schedule": "32 6 * * *"
    }
  ],
  "healthchecks": {
    "web": [
      {
        "type": "startup",
        "name": "web check",
        "description": "Checking if the app responds to the /",
        "path": "/",
        "attempts": 3,
        "content": "ok"
      }
    ]
  }
}
